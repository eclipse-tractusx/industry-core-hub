{
  "name": "ichub-frontend",
  "private": true,
  "version": "0.4.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:9000": "VITE_ICHUB_BACKEND_URL=http://localhost:9000/v1 VITE_PARTICIPANT_ID=BPNL0000000093Q7 vite --port 5173",
    "dev:9001": "VITE_ICHUB_BACKEND_URL=http://localhost:9001/v1 VITE_PARTICIPANT_ID=BPNL00000003CRHK vite --port 5174",
    "build": "vite build",
    "build:full": "tsc -b && vite build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "preview": "vite preview",
    "build:docker": "IMAGE=ichub-frontend && docker build -t $IMAGE -f Dockerfile .",
    "start:docker": "IMAGE=ichub-frontend && docker run --rm -d -p 8080:80 --name ichub-frontend $IMAGE"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@mui/icons-material": "^6.4.5",
    "@mui/material": "^6.4.5",
    "@mui/x-charts": "^8.3.1",
    "@mui/x-data-grid": "^8.11.1",
    "@yudiel/react-qr-scanner": "^2.0.8",
    "axios": "^1.15.0",
    "html2canvas": "^1.4.1",
    "i18next": "^25.8.0",
    "i18next-browser-languagedetector": "^8.2.0",
    "jspdf": "^4.2.1",
    "keycloak-js": "^25.0.6",
    "qrcode.react": "^4.2.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-i18next": "^16.5.3",
    "react-router-dom": "^7.12.0",
    "recharts": "^2.15.1",
    "sass": "^1.85.1",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react-swc": "^4.3.0",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  }
}
