{
  "name": "ichub-frontend",
  "private": true,
  "version": "0.4.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:9000": "VITE_ICHUB_BACKEND_URL=http://localhost:9000/v1 VITE_PARTICIPANT_ID=BPNL0000000093Q7 vite --port 5173",
    "dev:9001": "VITE_ICHUB_BACKEND_URL=http://localhost:9001/v1 VITE_PARTICIPANT_ID=BPNL00000003CRHK vite --port 5174",
    "build": "vite build",
    "build:full": "tsc -b && vite build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "preview": "vite preview",
    "build:docker": "IMAGE=ichub-frontend && docker build -t $IMAGE -f Dockerfile .",
    "start:docker": "IMAGE=ichub-frontend && docker run --rm -d -p 8080:80 --name ichub-frontend $IMAGE"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@mui/icons-material": "^9.0.0",
    "@mui/material": "^9.0.0",
    "@mui/x-charts": "^9.0.4",
    "@mui/x-data-grid": "^9.0.4",
    "@yudiel/react-qr-scanner": "^2.5.1",
    "axios": "^1.16.0",
    "html2canvas": "^1.4.1",
    "i18next": "^26.0.8",
    "i18next-browser-languagedetector": "^8.2.1",
    "jspdf": "^4.2.1",
    "keycloak-js": "^26.2.4",
    "qrcode.react": "^4.2.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-i18next": "^17.0.6",
    "react-router-dom": "^7.14.2",
    "recharts": "^3.8.1",
    "sass": "^1.99.0",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.19.0",
    "@types/node": "^22.15.19",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react-swc": "^3.5.0",
    "eslint": "^9.19.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.18",
    "globals": "^15.14.0",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.22.0",
    "vite": "^6.4.2",
    "vitest": "^3.2.4"
  }
}
